{
  "name": "@smartphonecracy/studio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:proof": "vite --config vite.proof.config.ts",
    "build": "tsc --noEmit && vite build",
    "build:proof": "tsc --noEmit && vite build --config vite.proof.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@smartphonecracy/studio-adapter": "workspace:*",
    "@smartphonecracy/tool-ui": "workspace:*",
    "@xyflow/react": "^12.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
